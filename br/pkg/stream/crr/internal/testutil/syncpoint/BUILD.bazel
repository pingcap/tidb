go_test(
    name = "syncpoint_test",
    timeout = "short",
    srcs = ["syncpoint_test.go"],
    embed = [":syncpoint"],
    flaky = True,
    deps = [
        "@com_github_pingcap_failpoint//:failpoint",
        "@com_github_stretchr_testify//require",
    ],
)
