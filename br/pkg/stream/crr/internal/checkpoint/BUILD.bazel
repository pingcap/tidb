load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "checkpoint",
    srcs = [
        "calculator.go",
        "doc.go",
        "progress.go",
        "storage.go",
    ],
    importpath = "github.com/pingcap/tidb/br/pkg/stream/crr/internal/checkpoint",
    visibility = ["//br/pkg/stream/crr:__subpackages__"],
    deps = [
        "//br/pkg/stream",
        "//br/pkg/stream/backupmetas",
        "//br/pkg/streamhelper",
        "//pkg/objstore/storeapi",
