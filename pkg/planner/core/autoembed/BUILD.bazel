go_test(
    name = "autoembed_test",
    timeout = "short",
    srcs = ["resolver_test.go"],
    embed = [":autoembed"],
    flaky = True,
    deps = [
        "//pkg/expression",
        "//pkg/expression/aggregation",
        "//pkg/meta/autoid",
        "//pkg/meta/model",
        "//pkg/parser/ast",
        "//pkg/parser/mysql",
        "//pkg/planner/core/base",
        "//pkg/planner/core/operator/logicalop",
        "//pkg/table/tables",
        "//pkg/types",
        "//pkg/util/mock",
        "@com_github_stretchr_testify//require",
    ],
)
