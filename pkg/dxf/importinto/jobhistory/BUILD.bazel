load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "jobhistory",
    srcs = ["history.go"],
    importpath = "github.com/pingcap/tidb/pkg/dxf/importinto/jobhistory",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/dxf/framework/proto",
        "//pkg/dxf/framework/storage",
