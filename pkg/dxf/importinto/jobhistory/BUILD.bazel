go_test(
    name = "jobhistory_test",
    timeout = "short",
    srcs = ["history_test.go"],
    flaky = True,
    deps = [
        ":jobhistory",
        "//pkg/dxf/framework/proto",
        "//pkg/dxf/framework/testutil",
        "//pkg/dxf/importinto/taskkey",
        "@com_github_stretchr_testify//require",
    ],
)
