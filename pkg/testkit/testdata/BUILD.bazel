load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "testdata",
    srcs = ["testdata.go"],
    importpath = "github.com/pingcap/tidb/pkg/testkit/testdata",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/util/context",
        "@com_github_stretchr_testify//require",
    ],
)

go_test(
    name = "testdata_test",
    timeout = "short",
    srcs = ["testdata_test.go"],
    embed = [":testdata"],
    flaky = True,
    shard_count = 3,
)
