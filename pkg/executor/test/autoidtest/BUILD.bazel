        "main_test.go",
    ],
    flaky = True,
    race = "on",
    shard_count = 10,
    deps = [
        "//pkg/autoid_service",
        "//pkg/config",
        "//pkg/ddl/testutil",
        "//pkg/meta/autoid",
        "//pkg/parser/mysql",
        "//pkg/sessionctx/variable",
        "//pkg/testkit",
        "//pkg/testkit/testutil",
        "@com_github_pingcap_failpoint//:failpoint",
        "@com_github_stretchr_testify//require",
        "@com_github_tikv_client_go_v2//tikv",
        "@org_uber_go_goleak//:goleak",
    ],
