load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "panictest",
    srcs = [
        "main_intest.go",
        "main_mega_init.go",
        "panic_intest.go",
        "register_gen.go",
    ],
    importpath = "github.com/pingcap/tidb/pkg/executor/test/analyzetest/panictest",
    visibility = [
        "//visibility:public",
    ],
    deps = [
        "//pkg/config",
        "//pkg/testkit",
        "//pkg/testkit/mega/register",
        "@com_github_pingcap_failpoint//:failpoint",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_goleak//:goleak",
    ],
)

go_test(
    name = "panictest_test",
    timeout = "short",
    srcs = [
        "main_test.go",
        "panic_test.go",
    ],
    flaky = True,
    shard_count = 4,
    deps = [
        "//pkg/config",
        "//pkg/testkit",
        "@com_github_pingcap_failpoint//:failpoint",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_goleak//:goleak",
    ],
)
