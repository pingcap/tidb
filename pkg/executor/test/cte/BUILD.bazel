load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "cte",
    srcs = [
        "cte_intest.go",
        "main_intest.go",
        "main_mega_init.go",
        "register_gen.go",
    ],
    importpath = "github.com/pingcap/tidb/pkg/executor/test/cte",
    visibility = [
        "//visibility:public",
    ],
    deps = [
        "//pkg/config",
        "//pkg/parser/terror",
        "//pkg/testkit",
        "//pkg/testkit/mega/register",
        "//pkg/testkit/testsetup",
        "//pkg/types",
        "@com_github_pingcap_failpoint//:failpoint",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_goleak//:goleak",
