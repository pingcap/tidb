set global tidb_enable_procedure = ON;
use test;
drop function if exists word_count;
drop function if exists plus_one;
create function word_count returns integer soname 'udf_word_count.so';
create function plus_one returns integer soname 'udf_plus_one.so';
select name, ret, dl, type from mysql.func where name in ('word_count', 'plus_one') order by name;
name	ret	dl	type
plus_one	2	udf_plus_one.so	function
word_count	2	udf_word_count.so	function
select word_count('hello world');
word_count('hello world')
2
select word_count('  hello   world  ');
word_count('  hello   world  ')
2
select word_count('');
word_count('')
0
select word_count(NULL);
word_count(NULL)
NULL
select plus_one(41);
plus_one(41)
42
select plus_one(NULL);
plus_one(NULL)
NULL
drop function word_count;
drop function plus_one;
select name from mysql.func where name in ('word_count', 'plus_one') order by name;
name
