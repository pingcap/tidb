use test;
drop table if exists t;
create table t (
  c0 int not null,
  c1 int unsigned not null,
  c2 double not null,
  c3 decimal(20, 3) not null,
  kcol int
);

select count(*) from information_schema.tidb_mviews;
select * from information_schema.tidb_mviews;

create materialized view log on t (c0, c1, c2, c3, kcol);

CREATE MATERIALIZED VIEW mv_t (kcol, s0, s1, s2, s3, cnt)
REFRESH FAST NEXT DATE_ADD(now(), interval 1 hour)
AS
SELECT kcol, SUM(c0), SUM(c1), SUM(c2), SUM(c3), COUNT(1)
FROM t
GROUP BY kcol;

CREATE MATERIALIZED VIEW mv_t1 (kcol, s0, s1, s2, s3, cnt)
REFRESH FAST NEXT DATE_ADD(now(), interval 1 hour)
AS
SELECT kcol, SUM(c0), SUM(c1), SUM(c2), SUM(c3), COUNT(1)
FROM t
GROUP BY kcol;

CREATE MATERIALIZED VIEW mvv_t1 (kcol, s0, s1, s2, s3, cnt)
REFRESH FAST NEXT DATE_ADD(now(), interval 1 hour)
AS
SELECT kcol, SUM(c0), SUM(c1), SUM(c2), SUM(c3), COUNT(1)
FROM t
GROUP BY kcol;

select count(*) from information_schema.tidb_mviews;
select * from information_schema.tidb_mviews;
select * from information_schema.tidb_mviews where TABLE_SCHEMA = "test";
select * from information_schema.tidb_mviews where TABLE_SCHEMA != "test";
select * from information_schema.tidb_mviews where MVIEW_NAME = "mv_t";
select * from information_schema.tidb_mviews where MVIEW_NAME = "mv_t" or MVIEW_NAME = "mv_t1";
select TABLE_SCHEMA, MVIEW_ID, MVIEW_NAME, MVIEW_MODIFY_TIME, REFRESH_METHOD from information_schema.tidb_mviews where MVIEW_NAME = "mv_t" or MVIEW_NAME like "%mvv%";
select * from information_schema.tidb_mviews where MVIEW_NAME in ("mv_t", "mv", "mv_t1");
select * from information_schema.tidb_mviews where MVIEW_NAME not in ("mv", "mv_t1");
select * from information_schema.tidb_mviews where TABLE_SCHEMA = "test" and MVIEW_NAME like "%mvv%";
select * from information_schema.tidb_mviews where REFRESH_METHOD = "FAST";
select * from information_schema.tidb_mviews where REFRESH_METHOD != "FAST";
select TABLE_SCHEMA, MVIEW_ID, MVIEW_NAME, MVIEW_MODIFY_TIME, REFRESH_METHOD from information_schema.tidb_mviews where MVIEW_NAME in ("mv_t", "mv", "mv_t1") and REFRESH_METHOD = "FAST";