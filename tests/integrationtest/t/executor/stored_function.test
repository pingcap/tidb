CREATE FUNCTION fn1( f1 MEDIUMTEXT ) RETURNS MEDIUMTEXT
   SQL SECURITY DEFINER COMMENT 'this is simple'
BEGIN
   SET @v1 = 'hello';
   SET f1 = CONCAT( @v1, f1 );
   RETURN f1;
END//
