BEGIN
    declare xx int;
    set xx = 'asd';
    GET DIAGNOSTICS @n = NUMBER;
    GET DIAGNOSTICS CONDITION @n @err_no = MYSQL_ERRNO, @err_txt = MESSAGE_TEXT;
    set @xx = xx;
