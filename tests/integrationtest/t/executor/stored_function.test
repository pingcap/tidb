delimiter //
CREATE PROCEDURE sp4()
BEGIN
    declare idummy int default 10;
    declare count int;
    set count = 1;
    label1: loop
    BEGIN
        if count < 20 then
            BEGIN
                declare idummy2 int default 10;
                set count=count+1;
            END;
        else
            BEGIN
                SELECT idummy2;
                leave label1;
            END;
        END if;
        iterate label1;
    END;
    END loop label1;
END//
delimiter ;

--error ER_BAD_FIELD_ERROR
CALL sp4();

# cleanup
DROP PROCEDURE sp4;


