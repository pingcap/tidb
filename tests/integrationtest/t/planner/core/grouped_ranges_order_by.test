and c > 1 order by c;

drop table if exists tp;
CREATE TABLE tp (
  a int,
  b int,
  c int,
  d int,
  primary key (a,b,d) /*T![clustered_index] CLUSTERED */
) PARTITION BY RANGE(d) (
  PARTITION p0 VALUES LESS THAN (100),
  PARTITION p1 VALUES LESS THAN (200),
  PARTITION p2 VALUES LESS THAN (300)
);

