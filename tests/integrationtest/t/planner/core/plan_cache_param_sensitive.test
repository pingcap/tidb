# Generic plan switch should be part of the plan cache key.
drop table if exists t_pc_key;
create table t_pc_key (a int primary key);
insert into t_pc_key values (1), (2);
set @@tidb_enable_prepared_plan_cache=1;
set @@tidb_enable_plan_cache_generic_plan=0;
prepare st from 'select a from t_pc_key where a = ?';
set @a=1;
execute st using @a;
select @@last_plan_from_cache;
execute st using @a;
select @@last_plan_from_cache;
set @@tidb_enable_plan_cache_generic_plan=1;
execute st using @a;
select @@last_plan_from_cache;
execute st using @a;
select @@last_plan_from_cache;
deallocate prepare st;

# Generic plan should not reuse unsafe point-get-like plans derived from mutable ranges.
drop table if exists t_gp_unique;
create table t_gp_unique (a int, b int, c int, unique key(a, b));
insert into t_gp_unique values (1, 1, 10), (1, 2, 20), (1, 3, 30);
set @@tidb_enable_plan_cache_generic_plan=1;
prepare st from 'select c from t_gp_unique where a=1 and b>=? and b<=? order by c';
set @l=1, @r=1;
execute st using @l, @r;
select @@last_plan_from_cache;
set @l=1, @r=2;
execute st using @l, @r;
select @@last_plan_from_cache;
deallocate prepare st;

# Generic plan can reuse conservative secondary-index range templates.
drop table if exists t_gp_range;
create table t_gp_range (id int primary key, a int, b int, key idx_a(a));
insert into t_gp_range values (1, 1, 10), (2, 1, 20), (3, 2, 30), (4, 3, 40);
set @@tidb_enable_plan_cache_generic_plan=0;
prepare st from 'select /*+ use_index(t_gp_range, idx_a) */ id from t_gp_range where a>=? and a<=? order by id';
set @x=1, @y=1;
execute st using @x, @y;
select @@last_plan_from_cache;
set @x=2, @y=2;
execute st using @x, @y;
select @@last_plan_from_cache;
deallocate prepare st;
set @@tidb_enable_plan_cache_generic_plan=1;
prepare st from 'select /*+ use_index(t_gp_range, idx_a) */ id from t_gp_range where a>=? and a<=? order by id';
set @x=1, @y=1;
execute st using @x, @y;
select @@last_plan_from_cache;
set @x=2, @y=2;
execute st using @x, @y;
select @@last_plan_from_cache;
deallocate prepare st;

# Generic plan should avoid parameter-sensitive same-column and propagated rewrites.
drop table if exists t_gp_eq;
create table t_gp_eq (a int, key(a));
insert into t_gp_eq values (1), (2);
set @@tidb_enable_plan_cache_generic_plan=0;
prepare st from 'select a from t_gp_eq where a=? and a=? order by a';
set @x=1, @y=2;
execute st using @x, @y;
select @@last_plan_from_cache;
set @x=1, @y=1;
execute st using @x, @y;
select @@last_plan_from_cache;
deallocate prepare st;
set @@tidb_enable_plan_cache_generic_plan=1;
prepare st from 'select a from t_gp_eq where a=? and a=? order by a';
set @x=1, @y=2;
execute st using @x, @y;
select @@last_plan_from_cache;
set @x=1, @y=1;
execute st using @x, @y;
select @@last_plan_from_cache;
deallocate prepare st;

drop table if exists t_gp_cp;
create table t_gp_cp (a int, b int, key(a), key(b));
insert into t_gp_cp values (1, 1), (2, 2);
set @@tidb_enable_plan_cache_generic_plan=0;
prepare st from 'select a, b from t_gp_cp where a=b and a=? and b=? order by a';
set @x=1, @y=2;
execute st using @x, @y;
select @@last_plan_from_cache;
set @x=1, @y=1;
execute st using @x, @y;
select @@last_plan_from_cache;
deallocate prepare st;
set @@tidb_enable_plan_cache_generic_plan=1;
prepare st from 'select a, b from t_gp_cp where a=b and a=? and b=? order by a';
set @x=1, @y=2;
execute st using @x, @y;
select @@last_plan_from_cache;
set @x=1, @y=1;
execute st using @x, @y;
select @@last_plan_from_cache;
deallocate prepare st;

# Generic plan should keep NE/IN simplification conservative but reusable.
drop table if exists t_gp_in;
create table t_gp_in (a int, key(a));
insert into t_gp_in values (1), (2), (3);
set @@tidb_enable_plan_cache_generic_plan=0;
prepare st from 'select a from t_gp_in where a in (?, ?) and a <> ? order by a';
set @x=1, @y=2, @z=1;
execute st using @x, @y, @z;
select @@last_plan_from_cache;
set @x=1, @y=2, @z=2;
execute st using @x, @y, @z;
select @@last_plan_from_cache;
deallocate prepare st;
set @@tidb_enable_plan_cache_generic_plan=1;
prepare st from 'select a from t_gp_in where a in (?, ?) and a <> ? order by a';
set @x=1, @y=2, @z=1;
execute st using @x, @y, @z;
select @@last_plan_from_cache;
set @x=1, @y=2, @z=2;
execute st using @x, @y, @z;
select @@last_plan_from_cache;
deallocate prepare st;

# Outer-join null-reject inference remains conservative in generic-plan mode for mutable predicates.
drop table if exists t_gp_left1, t_gp_left2;
create table t_gp_left1 (a int, key(a));
create table t_gp_left2 (a int, b int, key(a), key(b));
insert into t_gp_left1 values (1), (2), (3);
insert into t_gp_left2 values (1, 1), (2, 2), (3, null);
set @@tidb_enable_plan_cache_generic_plan=0;
prepare st from 'select t_gp_left1.a from t_gp_left1 left join t_gp_left2 on t_gp_left1.a=t_gp_left2.a where t_gp_left2.b > ? order by t_gp_left1.a';
set @p=0;
execute st using @p;
select @@last_plan_from_cache;
set @p=1;
execute st using @p;
select @@last_plan_from_cache;
deallocate prepare st;
set @@tidb_enable_plan_cache_generic_plan=1;
prepare st from 'select t_gp_left1.a from t_gp_left1 left join t_gp_left2 on t_gp_left1.a=t_gp_left2.a where t_gp_left2.b > ? order by t_gp_left1.a';
set @p=0;
execute st using @p;
select @@last_plan_from_cache;
set @p=1;
execute st using @p;
select @@last_plan_from_cache;
deallocate prepare st;

set @@tidb_enable_plan_cache_generic_plan=default;
set @@tidb_enable_prepared_plan_cache=default;
