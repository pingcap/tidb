create table t1 (aid int not null primary key, balance int not null default 0);
insert into t1 values (1, 1000), (2,3000);
create trigger trg before update on t1 for each row
begin
declare loc_err varchar(255);
if abs(new.balance - old.balance) > 1000 then
set new.balance:= old.balance;
set loc_err := concat("Too big change for aid = ", new.aid);
set @update_failed:= if(@update_failed, concat(@a, ":", loc_err), loc_err);
end if;
end|
set @update_failed:=""|
update t1 set balance=1500|
select @update_failed|
@update_failed
Too big change for aid = 2
select * from t1|
aid	balance
1	1500
2	3000
drop trigger trg|
drop table t1|
create database if not exists trig_db;
use trig_db;
set @@tidb_enable_noop_functions='ON';
create table t_upd_ts (
prod_id char(3) not null default '',
prem_pay_period decimal(3,0) not null default '0',
pay_freq_type int not null default '0',
age_low_limit decimal(3,0) default '0',
age_high_limit decimal(3,0) default '0',
upd_ts datetime default null,
primary key (prod_id,prem_pay_period,pay_freq_type) /*T![clustered_index] CLUSTERED */,
key t_upd_ts_idx1 (prod_id)
) engine=innodb default charset=utf8mb4 collate=utf8mb4_bin;
create trigger t_upd_ts_upd
before update on t_upd_ts
for each row
begin
set new.UPD_TS = current_timestamp;
end$$
insert into t_upd_ts(prod_id, prem_pay_period, pay_freq_type) values ('p01', 1, 1);
update t_upd_ts set age_low_limit = 1 where prod_id='p01' and prem_pay_period=1 and pay_freq_type=1;
select upd_ts is not null from t_upd_ts;
upd_ts is not null
1
drop trigger t_upd_ts_upd;
drop table t_upd_ts;
use executor__trigger_simple;
drop database trig_db;
set @@tidb_enable_noop_functions='OFF';
create table t_label (id int primary key, note varchar(20));
insert into t_label values (1, 'same');
create trigger trg_label before update on t_label for each row
labeltri: begin
if new.note = old.note then
leave labeltri;
end if;
set new.note = concat(new.note, '_changed');
end labeltri$$
show create trigger trg_label;
Trigger	sql_mode	SQL Original Statement	character_set_client	collation_connection	Database Collation	Created
trg_label	ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION,NO_ZERO_DATE,NO_ZERO_IN_DATE,ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES	CREATE DEFINER = `root`@`127.0.0.1` TRIGGER `executor__trigger_simple`.`trg_label` BEFORE UPDATE ON `executor__trigger_simple`.`t_label` FOR EACH ROW `labeltri`: BEGIN IF `new`.`note`=`old`.`note` THEN LEAVE `labeltri`;END IF;SET `new.note`=CONCAT(`new`.`note`, _UTF8MB4'_changed'); END `labeltri`	utf8mb4	utf8mb4_general_ci	utf8mb4_bin	<created>
update t_label set note = 'same' where id = 1;
select note from t_label where id = 1;
note
same
update t_label set note = 'new' where id = 1;
select note from t_label where id = 1;
note
new_changed
drop trigger trg_label;
drop table t_label;
