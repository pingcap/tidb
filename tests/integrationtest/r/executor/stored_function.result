declare var6 year(4);
declare var7 year(4);
declare var8 year(4);
set var1 = 51;
set var3 = 51;
set var5 = 1982;
set var7 = 1982;
CALL sp1(51, var1, var2, 51, var3, var4, 1982, var5, var6, 1982, var7, var8);
SELECT var1, var2, var3, var4, var5, var6, var7, var8;
END//
