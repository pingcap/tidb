drop user if exists dpu1, dpadmin, dpvictim;
create user dpu1 identified by 'old';
alter user dpu1 identified by 'new' retain current password;
select json_extract(user_attributes, '$.additional_password') is not null from mysql.user where user = 'dpu1';
json_extract(user_attributes, '$.additional_password') is not null
1
alter user dpu1 discard old password;
select json_extract(user_attributes, '$.additional_password') from mysql.user where user = 'dpu1';
json_extract(user_attributes, '$.additional_password')
NULL
alter user dpu1 identified by 'a' retain current password;
select json_extract(user_attributes, '$.additional_password') is not null from mysql.user where user = 'dpu1';
json_extract(user_attributes, '$.additional_password') is not null
1
alter user dpu1 identified with caching_sha2_password by 'b';
select json_extract(user_attributes, '$.additional_password') from mysql.user where user = 'dpu1';
json_extract(user_attributes, '$.additional_password')
NULL
create user dpu2 identified by 'x' retain current password;
Error 1105 (HY000): RETAIN CURRENT PASSWORD clause is not supported in CREATE USER statement
alter user dpu1 identified with mysql_native_password by 'c';
alter user dpu1 identified with caching_sha2_password by 'd' retain current password;
Error 4058 (HY000): Current password can not be retained for user 'dpu1'@'%' because authentication plugin is being changed.
alter user dpu1 identified by '' retain current password;
Error 4059 (HY000): Current password can not be retained for user 'dpu1'@'%' because new password is empty.
drop user dpu1;
create user dpu1 identified by 'p1';
set password for dpu1 = 'p2' retain current password;
select json_extract(user_attributes, '$.additional_password') is not null from mysql.user where user = 'dpu1';
json_extract(user_attributes, '$.additional_password') is not null
1
create user dpvictim identified by 'v1';
create user dpadmin identified by 'a1';
grant create user on *.* to dpadmin;
grant select on test.* to dpadmin;
alter user dpvictim identified by 'v2' retain current password;
Error 1227 (42000): Access denied; you need (at least one of) the APPLICATION_PASSWORD_ADMIN privilege(s) for this operation
grant application_password_admin on *.* to dpadmin;
alter user dpvictim identified by 'v2' retain current password;
select json_extract(user_attributes, '$.additional_password') is not null from mysql.user where user = 'dpvictim';
json_extract(user_attributes, '$.additional_password') is not null
1
