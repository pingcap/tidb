drop procedure if exists p_explain_routine_nested_helper;
create procedure p_explain_routine_nested_helper(id int)
begin
declare v int default 0;
select b into v from t_explain_routine where a = id;
end//
drop procedure if exists p_explain_routine_nested_parent;
create procedure p_explain_routine_nested_parent(id int)
begin
call p_explain_routine_nested_helper(id);
select * from t_explain_routine where a = id;
end//
explain analyze routine procedure p_explain_routine_nested_parent(1);
