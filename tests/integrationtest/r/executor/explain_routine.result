set global tidb_enable_procedure = ON;
drop database if exists db_explain_routine;
create database db_explain_routine;
use db_explain_routine;
drop table if exists t_explain_routine;
create table t_explain_routine(a int, b int, key idx_a(a));
insert into t_explain_routine values (1, 10), (2, 20), (3, 30);
drop procedure if exists p_explain_routine_summary;
create procedure p_explain_routine_summary(id int)
begin
if id > 10 then
select * from t_explain_routine where a = id;
end if;
select * from t_explain_routine where a = id;
end//
explain analyze routine procedure p_explain_routine_summary(1);
