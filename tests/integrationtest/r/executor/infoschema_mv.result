$mlog$tmlogbrb	tmlogbrb
select mlog_name, purge_method
from information_schema.tidb_mlogs
where table_catalog like 'de%'
and base_table_catalog like 'de%'
and mlog_columns like '%id%'
and purge_next like 'DATE_ADD%';
mlog_name	purge_method
$mlog$tmlogbra	DEFERRED
$mlog$tmlogbrb	DEFERRED
$mlog$tmlog_like_a	DEFERRED
$mlog$tmlog_like_b	DEFERRED
$mlog$tmlog_misc_c	DEFERRED
