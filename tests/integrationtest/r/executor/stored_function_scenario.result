set global tidb_enable_procedure = ON;
DROP TABLE IF EXISTS salary_adjustment_logs;
DROP TABLE IF EXISTS employees_622;
CREATE TABLE employees_622 (
employee_id   INT PRIMARY KEY,
first_name    VARCHAR(50),
last_name     VARCHAR(50) NOT NULL,
commission_pct DECIMAL(4, 2),
hire_date     DATE,
job_id        VARCHAR(10),
salary        DECIMAL(8, 2),
manager_id    INT,
department_id INT
);
CREATE TABLE salary_adjustment_logs (
employee_id INT,
salary_old DECIMAL(8,2),
salary_new DECIMAL(8,2),
create_time DATETIME
);
