Policy_name	Column_name	Expression	Status	Masking_type	Restrict_on
p_lifecycle	c	CASE WHEN CURRENT_USER() IN (_UTF8MB4'root@%',_UTF8MB4'cmp_allowed@%') THEN `c` ELSE MASK_FULL(`c`) END	ENABLED	CUSTOM	NONE
