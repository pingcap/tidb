CREATE MASKING POLICY p_lifecycle ON privilege__column_masking_policy.t_lifecycle(c)
AS CASE WHEN current_user() IN ('root@%', 'cmp_allowed@%') THEN c ELSE MASK_FULL(c) END ENABLE;
