select `id`, `review_count`, `rating`, `embedding_title`, `embedding_content` from `recipes`
where 1 = 1 and `embedding_title` is not null and `embedding_content` is not null
order by
coalesce((((ifnull(`review_count`, 0) * ifnull(`rating`, 0)) + 0) / (ifnull(`review_count`, 0) + 1)), 0) desc,
(1 * (1 - vec_cosine_distance(`embedding_title`, '[1,0,0]'))) + (1 * (1 - vec_cosine_distance(`embedding_content`, '[1,0,0]'))) desc
limit 2 offset 0;
