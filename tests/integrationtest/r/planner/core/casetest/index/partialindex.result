create table t(
a int, b int, c int,
index idx1(a) where a is not null,
index idx2(b) where b > 2,
unique index idx3(c) where b > 10
);
create table tt(
a int, b int, c int,
index idx1(a),
index idx2(b),
unique index idx3(c)
);
