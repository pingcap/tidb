              ├─IndexRangeScan(Build)	100000.00	cop[tikv]	table:i, index:idx_k_ts(k, ts)	range: decided by [eq(planner__core__casetest__hint__join_to_apply.jt_inner.k, planner__core__casetest__hint__join_to_apply.jt_outer.a)], keep order:false, stats:pseudo
