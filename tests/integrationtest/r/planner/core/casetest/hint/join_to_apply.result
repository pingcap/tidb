set tidb_cost_model_version=2;
drop table if exists jt_outer, jt_inner, jt_outer_multi, jt_inner_multi;
create table jt_outer(a int, b int);
create table jt_inner(k int, ts int, v int, index idx_k_ts(k, ts));
create table jt_outer_multi(a int, b int);
create table jt_inner_multi(a int, b int, ts int, v int, index idx_ab_ts(a, b, ts));
explain format = 'brief'
select /*+ JOIN_TO_APPLY() */ o.a, f.v
from jt_outer o
left join (
select i.k as fk, i.v,
row_number() over (partition by i.k order by i.ts desc) as rn
from jt_inner i use index(idx_k_ts)
) f on o.a = f.fk and f.rn = 1;
id	estRows	task	access object	operator info
